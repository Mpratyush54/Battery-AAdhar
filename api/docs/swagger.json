{
    "swagger": "2.0",
    "info": {
        "description": "The Go Gateway for the BPA and Zero-Knowledge Rides application.",
        "title": "Battery Pack Aadhaar / zk_rides API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:3000",
    "basePath": "/",
    "paths": {
        "/api/v1/battery/register": {
            "post": {
                "description": "Registers a new battery with the BPA Core Engine",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "battery"
                ],
                "summary": "Register a new battery",
                "parameters": [
                    {
                        "description": "Battery registration payload",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.RegisterBatteryPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful registration",
                        "schema": {
                            "$ref": "#/definitions/main.RegisterBatteryResponseJSON"
                        }
                    },
                    "400": {
                        "description": "Invalid payload",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "405": {
                        "description": "Method not allowed",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server/Microservice Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/v1/rides": {
            "get": {
                "description": "Retrieves all rides decrypted by the Rust backend",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rides"
                ],
                "summary": "Get all rides",
                "responses": {
                    "200": {
                        "description": "List of rides",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/main.RideResponseJSON"
                            }
                        }
                    },
                    "405": {
                        "description": "Method not allowed",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server/Microservice Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a ride by passing a ZkProof and details to the Rust gRPC backend",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rides"
                ],
                "summary": "Create a new ride",
                "parameters": [
                    {
                        "description": "Ride creation payload",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.RidePayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful ride creation",
                        "schema": {
                            "$ref": "#/definitions/main.RideResponseJSON"
                        }
                    },
                    "400": {
                        "description": "Invalid payload",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "405": {
                        "description": "Method not allowed",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server/Microservice Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.RegisterBatteryPayload": {
            "type": "object",
            "properties": {
                "actorId": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000"
                },
                "batchNumber": {
                    "type": "string",
                    "example": "BAT2026"
                },
                "batteryCategory": {
                    "type": "string",
                    "example": "EV-M"
                },
                "chemistryType": {
                    "type": "string",
                    "example": "LFP"
                },
                "complianceClass": {
                    "type": "string",
                    "example": "AIS-156"
                },
                "energyDensity": {
                    "type": "number",
                    "example": 150
                },
                "factoryCode": {
                    "type": "string",
                    "example": "FAC01"
                },
                "formFactor": {
                    "type": "string",
                    "example": "PRISMATIC"
                },
                "manufacturerCode": {
                    "type": "string",
                    "example": "ABC"
                },
                "manufacturerId": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000"
                },
                "nominalVoltage": {
                    "type": "number",
                    "example": 48
                },
                "productionYear": {
                    "type": "integer",
                    "example": 2026
                },
                "ratedCapacityKwh": {
                    "type": "number",
                    "example": 2.5
                },
                "sequenceNumber": {
                    "type": "string",
                    "example": "01"
                },
                "serialNumber": {
                    "type": "string",
                    "example": "SN12345678"
                },
                "weightKg": {
                    "type": "number",
                    "example": 25
                }
            }
        },
        "main.RegisterBatteryResponseJSON": {
            "type": "object",
            "properties": {
                "bpan": {
                    "type": "string"
                },
                "registrationId": {
                    "type": "string"
                },
                "staticHash": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "main.RidePayload": {
            "description": "Payload containing the zero-knowledge proof and ride details",
            "type": "object",
            "properties": {
                "rideDetails": {
                    "type": "string",
                    "example": "New ride details..."
                },
                "zkProof": {
                    "type": "string",
                    "example": "proof_payload_123"
                }
            }
        },
        "main.RideResponseJSON": {
            "description": "Complete ride details including its assigned ID",
            "type": "object",
            "properties": {
                "id": {
                    "type": "integer",
                    "example": 42
                },
                "rideDetails": {
                    "type": "string",
                    "example": "New ride details..."
                },
                "zkProof": {
                    "type": "string",
                    "example": "proof_payload_123"
                }
            }
        }
    }
}